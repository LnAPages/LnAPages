# Stripe secret key used by /functions/api/payments/*
STRIPE_SECRET_KEY=
# Stripe webhook signing secret used by /functions/api/payments/webhook
STRIPE_WEBHOOK_SECRET=
# Stripe publishable key for frontend usage
VITE_STRIPE_PUBLISHABLE_KEY=

# GitHub OAuth app client ID for admin login
GITHUB_OAUTH_CLIENT_ID=
# GitHub OAuth app client secret for admin login callback exchange
GITHUB_OAUTH_CLIENT_SECRET=
# GitHub repository owner username (always treated as admin)
GITHUB_REPO_OWNER=

# Resend API key used for notification emails
RESEND_API_KEY=
# Verified from-email for Resend outbound emails
RESEND_FROM_EMAIL=

# Twilio account SID used for SMS notifications
TWILIO_ACCOUNT_SID=
# Twilio auth token used for SMS notifications
TWILIO_AUTH_TOKEN=
# Twilio sender number (E.164 format)
TWILIO_FROM_NUMBER=

# Public app URL (e.g. https://fnlstage.com)
APP_URL=
# Public base URL for serving R2 files
R2_PUBLIC_BASE_URL=

# Optional Google Drive API key for faster public folder indexing
GOOGLE_DRIVE_API_KEY=
